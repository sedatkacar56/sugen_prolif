packageVersion("SeuratObject")
knitr::opts_chunk$set(echo = TRUE)
combined <- readRDS("combined.rds")
unique(combined@meta.data$group)
names(combined@reductions)
#Step 3 — Export data to JSON
#Run this in R. It will take 10–30 min for all genes. Paste any errors if it fails.
library(Seurat)
library(jsonlite)
seurat_obj <- combined
group_col  <- "group"
output_dir <- "C:/Users/skacar/OneDrive - Indiana University/Shiny/sugen_prolif"
# 1a. umap.json
umap_embed <- as.data.frame(seurat_obj@reductions$umap@cell.embeddings)
colnames(umap_embed) <- c("UMAP_1", "UMAP_2")
umap_df <- data.frame(
cell   = rownames(umap_embed),
UMAP_1 = umap_embed$UMAP_1,
UMAP_2 = umap_embed$UMAP_2,
group  = seurat_obj@meta.data[[group_col]],
stringsAsFactors = FALSE
)
write(toJSON(umap_df, dataframe = "rows", digits = 4), file.path(output_dir, "umap.json"))
message("umap.json written — ", nrow(umap_df), " cells")
# 1b. genes/*.json
genes_dir <- file.path(output_dir, "genes")
dir.create(genes_dir, showWarnings = FALSE)
expr_matrix <- GetAssayData(seurat_obj, layer = "data")
seurat_obj <- JoinLayers(seurat_obj)
expr_matrix <- GetAssayData(seurat_obj, layer = "data")
expr_matrix <- GetAssayData(seurat_obj, layer = "data")
cell_order  <- umap_df$cell
all_genes   <- rownames(expr_matrix)
for (i in seq_along(all_genes)) {
gene <- all_genes[i]
vals <- as.numeric(expr_matrix[gene, cell_order])
write(toJSON(list(gene = gene, values = vals), auto_unbox = TRUE, digits = 4),
file.path(genes_dir, paste0(gene, ".json")))
if (i %% 500 == 0) message(i, "/", length(all_genes), " genes exported")
}
# 1c. gene_list.json
gene_names <- tools::file_path_sans_ext(list.files(genes_dir))
write(toJSON(gene_names), file.path(output_dir, "gene_list.json"))
message("Done!")
unique(combined@meta.data$group)
