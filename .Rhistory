uwot.sgd           = p$uwot.sgd           %||% FALSE,
angular.rp.forest  = p$angular.rp.forest  %||% FALSE,
densmap            = p$densmap            %||% FALSE,
seed.use           = p$seed.use           %||% 42L,
reduction.name     = p$reduction.name     %||% "umap",
verbose            = TRUE,
return.model       = TRUE                 # key addition
)
# ── Sanity check: plot original vs rerun ─────────────────────────────────
message("[ Sanity check ] Plotting original vs re-run UMAP ...")
p_orig   <- plot_clusters(ref_seurat)
p_rerun  <- plot_clusters(ref_rerun)
print(p_orig | p_rerun)
ref <- ref_rerun
} else {
message("[ return.model = TRUE confirmed ] Using existing UMAP model.")
ref <- ref_seurat
}
# ── 3. Subset query sample(s) ──────────────────────────────────────────────
if (!is.null(query_samples)) {
message("[ Query ] Subsetting sample(s): ", paste(query_samples, collapse = ", "))
query <- subset(
query_seurat,
subset = !!rlang::sym(query_sample_col) %in% query_samples
)
} else {
message("[ Query ] No sample filter — using full query Seurat.")
query <- query_seurat
}
# ── 4. Transfer labels from ref to query ───────────────────────────────────
message("[ Transfer Labels ] Transferring: ", transfer_col)
query <- Transfer_Labels(
query_seurat = query,
reference    = ref,
mode         = "manual",
col_names    = transfer_col
)
# ── 5. FindTransferAnchors ─────────────────────────────────────────────────
message("[ Anchors ] Finding transfer anchors ...")
anchors <- Seurat::FindTransferAnchors(
reference           = ref,
query               = query,
dims                = 1:30,
reference.reduction = "pca"
)
# ── 6. MapQuery: project onto ref UMAP ────────────────────────────────────
message("[ MapQuery ] Projecting query onto reference UMAP ...")
query <- Seurat::MapQuery(
anchorset           = anchors,
query               = query,
reference           = ref,
reference.reduction = "pca",
reduction.model     = "umap"
)
# ── 7. Merge ref + query ──────────────────────────────────────────────────
message("[ Merge ] Combining ref and projected query ...")
combined <- merge(ref, query)
# ── 8. Unify UMAP embeddings ──────────────────────────────────────────────
ref_coords  <- Seurat::Embeddings(ref,   "umap")
proj_coords <- Seurat::Embeddings(query, "ref.umap")
colnames(proj_coords) <- colnames(ref_coords)
all_coords <- rbind(ref_coords, proj_coords)
combined[["umap"]] <- Seurat::CreateDimReducObject(
embeddings = all_coords[colnames(combined), ],
key        = "UMAP_",
assay      = Seurat::DefaultAssay(combined)
)
# ── 9. Late exclusion (default) ───────────────────────────────────────────
if (!is.null(exclude_samples) && !exclude_early) {
message("[ Late exclusion ] Removing: ", paste(exclude_samples, collapse = ", "))
combined <- subset(
combined,
subset = !!rlang::sym(ref_sample_col) %in% exclude_samples,
invert = TRUE
)
}
# ── 10. Final plots ───────────────────────────────────────────────────────
message("[ Plots ] Generating final plots ...")
p_ann    <- plot_clusters(combined, group_by = transfer_col,  split_by = "group")
p_sample <- plot_clusters(combined, group_by = transfer_col,  split_by = "sample")
print(p_ann)
print(p_sample)
message("[ Done ] Returning combined Seurat object.")
return(combined)
}
