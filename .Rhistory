#' Project a New Sample onto an Existing Reference UMAP
#'
#' @param ref_seurat      Seurat object containing the reference UMAP you want to preserve.
#' @param ref_sample_col  Metadata column name holding sample identifiers in ref_seurat.
#' @param exclude_samples Character vector of sample names to exclude from ref_seurat. Default NULL.
#' @param exclude_early   Logical. If TRUE, exclude samples before building the reference. Default FALSE.
#' @param query_seurat    Seurat object containing the new sample(s) to project.
#' @param query_sample_col Metadata column name holding sample identifiers in query_seurat.
#' @param query_samples   Character vector of sample name(s) to subset from query_seurat. Default NULL (use all).
#' @param transfer_col    Metadata column in ref_seurat holding cell type labels to transfer. Default "CleanAnn".
#'
#' @return Combined Seurat object with unified UMAP and projected query cells.
#'
#' @examples
#' combined <- project_onto_ref_umap(
#'   ref_seurat       = EnMesPaa_NoNa,
#'   ref_sample_col   = "sample",
#'   exclude_samples  = "RatSuHx2_PAA_R162_Female_12",
#'   exclude_early    = FALSE,
#'   query_seurat     = Endo_meso_paa5_NoNa,
#'   query_sample_col = "sample",
#'   query_samples    = "RatSuHx5_Female_5",
#'   transfer_col     = "CleanAnn"
#' )
project_onto_ref_umap <- function(
ref_seurat,
ref_sample_col,
exclude_samples  = NULL,
exclude_early    = FALSE,
query_seurat,
query_sample_col,
query_samples    = NULL,
transfer_col     = "CleanAnn"
) {
# ── 1. Early exclusion (optional) ──────────────────────────────────────────
if (!is.null(exclude_samples) && exclude_early) {
message("[ Early exclusion ] Removing: ", paste(exclude_samples, collapse = ", "))
ref_seurat <- subset(
ref_seurat,
subset = !!rlang::sym(ref_sample_col) %in% exclude_samples,
invert = TRUE
)
}
# ── 2. Check if return.model = TRUE in existing UMAP command ───────────────
umap_cmd_name <- "RunUMAP.integrated.pca"
umap_cmd      <- ref_seurat@commands[[umap_cmd_name]]
if (is.null(umap_cmd)) {
# fallback: try to find any RunUMAP command
umap_cmd_name <- grep("RunUMAP", names(ref_seurat@commands), value = TRUE)[1]
umap_cmd      <- ref_seurat@commands[[umap_cmd_name]]
}
model_stored <- isTRUE(umap_cmd@params$return.model) &&
!is.null(ref_seurat@reductions$umap@misc$model)
if (!model_stored) {
message("[ return.model = FALSE detected ] Re-running UMAP with return.model = TRUE ...")
# Extract original params
p <- umap_cmd@params
ref_rerun <- Seurat::DefaultAssay(ref_seurat) <- "integrated"   # set integrated as default assay
ref_rerun <- Seurat::RunUMAP(
ref_rerun,
dims               = p$dims,
reduction          = p$reduction          %||% "pca",
umap.method        = p$umap.method        %||% "uwot",
metric             = p$metric             %||% "cosine",
n.neighbors        = p$n.neighbors        %||% 30L,
n.components       = p$n.components       %||% 2L,
min.dist           = p$min.dist           %||% 0.3,
spread             = p$spread             %||% 1,
learning.rate      = p$learning.rate      %||% 1,
set.op.mix.ratio   = p$set.op.mix.ratio   %||% 1,
local.connectivity = p$local.connectivity %||% 1L,
repulsion.strength = p$repulsion.strength %||% 1,
negative.sample.rate = p$negative.sample.rate %||% 5L,
uwot.sgd           = p$uwot.sgd           %||% FALSE,
angular.rp.forest  = p$angular.rp.forest  %||% FALSE,
densmap            = p$densmap            %||% FALSE,
seed.use           = p$seed.use           %||% 42L,
reduction.name     = p$reduction.name     %||% "umap",
verbose            = TRUE,
return.model       = TRUE                 # key addition
)
# ── Sanity check: plot original vs rerun ─────────────────────────────────
message("[ Sanity check ] Plotting original vs re-run UMAP ...")
p_orig   <- plot_clusters(ref_seurat)
p_rerun  <- plot_clusters(ref_rerun)
print(p_orig | p_rerun)
ref <- ref_rerun
} else {
message("[ return.model = TRUE confirmed ] Using existing UMAP model.")
ref <- ref_seurat
}
# ── 3. Subset query sample(s) ──────────────────────────────────────────────
if (!is.null(query_samples)) {
message("[ Query ] Subsetting sample(s): ", paste(query_samples, collapse = ", "))
query <- subset(
query_seurat,
subset = !!rlang::sym(query_sample_col) %in% query_samples
)
} else {
message("[ Query ] No sample filter — using full query Seurat.")
query <- query_seurat
}
# ── 4. Transfer labels from ref to query ───────────────────────────────────
message("[ Transfer Labels ] Transferring: ", transfer_col)
query <- Transfer_Labels(
query_seurat = query,
reference    = ref,
mode         = "manual",
col_names    = transfer_col
)
# ── 5. FindTransferAnchors ─────────────────────────────────────────────────
message("[ Anchors ] Finding transfer anchors ...")
anchors <- Seurat::FindTransferAnchors(
reference           = ref,
query               = query,
dims                = 1:30,
reference.reduction = "pca"
)
# ── 6. MapQuery: project onto ref UMAP ────────────────────────────────────
message("[ MapQuery ] Projecting query onto reference UMAP ...")
query <- Seurat::MapQuery(
anchorset           = anchors,
query               = query,
reference           = ref,
reference.reduction = "pca",
reduction.model     = "umap"
)
# ── 7. Merge ref + query ──────────────────────────────────────────────────
message("[ Merge ] Combining ref and projected query ...")
combined <- merge(ref, query)
# ── 8. Unify UMAP embeddings ──────────────────────────────────────────────
ref_coords  <- Seurat::Embeddings(ref,   "umap")
proj_coords <- Seurat::Embeddings(query, "ref.umap")
colnames(proj_coords) <- colnames(ref_coords)
all_coords <- rbind(ref_coords, proj_coords)
combined[["umap"]] <- Seurat::CreateDimReducObject(
embeddings = all_coords[colnames(combined), ],
key        = "UMAP_",
assay      = Seurat::DefaultAssay(combined)
)
# ── 9. Late exclusion (default) ───────────────────────────────────────────
if (!is.null(exclude_samples) && !exclude_early) {
message("[ Late exclusion ] Removing: ", paste(exclude_samples, collapse = ", "))
combined <- subset(
combined,
subset = !!rlang::sym(ref_sample_col) %in% exclude_samples,
invert = TRUE
)
}
# ── 10. Final plots ───────────────────────────────────────────────────────
message("[ Plots ] Generating final plots ...")
p_ann    <- plot_clusters(combined, group_by = transfer_col,  split_by = "group")
p_sample <- plot_clusters(combined, group_by = transfer_col,  split_by = "sample")
print(p_ann)
print(p_sample)
message("[ Done ] Returning combined Seurat object.")
return(combined)
}
